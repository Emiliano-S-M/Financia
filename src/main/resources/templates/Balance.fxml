<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" styleClass="gray-background" stylesheets="@../styles/ColorsPalette.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CanalDev.Financia.Controlador.BalanceController">
   <children>
      <BorderPane prefHeight="200.0" prefWidth="200.0" styleClass="gray-background" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <center>
            <TableView fx:id="movimientosTabla" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
              <columns>
                  <TableColumn fx:id="idColumna" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="tipoColumna" prefWidth="75.0" text="Tipo" />
                <TableColumn fx:id="montoColumna" prefWidth="75.0" text="Monto" />
                <TableColumn fx:id="categoriaColumna" prefWidth="75.0" text="Categoria" />
                <TableColumn fx:id="fechaColumna" prefWidth="75.0" text="Fecha" />
                 <TableColumn fx:id="eliminarColumna" prefWidth="75.0">
                    <graphic>
                       <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                          <image>
                             <Image url="@../Imagenes/BoteBasura.png" />
                          </image>
                       </ImageView>
                    </graphic>
                 </TableColumn>
              </columns>
               <BorderPane.margin>
                  <Insets left="40.0" right="40.0" />
               </BorderPane.margin>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </center>
         <bottom>
            <AnchorPane BorderPane.alignment="CENTER">
               <children>
                  <Button fx:id="agregarMovimientoBoton" layoutX="389.0" layoutY="20.8" mnemonicParsing="false" onAction="#agregarMovimiento" text="Agregar Movimiento" AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <styleClass>
                        <String fx:value="green-background" />
                        <String fx:value="white-text" />
                     </styleClass>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="10.0" left="40.0" right="40.0" top="10.0" />
               </padding>
            </AnchorPane>
         </bottom>
         <top>
            <HBox prefHeight="113.0" prefWidth="600.0" styleClass="gray-background" BorderPane.alignment="CENTER">
               <children>
                  <VBox>
                     <children>
                        <Label styleClass="dark-text" text="Balance Total">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                        <Label fx:id="labelBalance" styleClass="green-text" text="\$999,999.99">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="saludoLabel" styleClass="gray-text" text="Hola buenos días">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
               </children>
               <padding>
                  <Insets left="40.0" right="40.0" top="40.0" />
               </padding>
            </HBox>
         </top>
      </BorderPane>
   </children>
</AnchorPane>
